# ═══════════════════════════════════════════════════════════════════════════════
# Gestão de Academias — .env de produção (VPS)
#
# Como usar:
#   cp .env.production.example .env
#   nano .env   ← preencha TODOS os valores marcados com PREENCHER
#   docker compose up -d --build
#
# ATENÇÃO: nunca versione este arquivo com valores reais.
# Adicione ".env" ao .gitignore (já está — este exemplo pode ser versionado).
# ═══════════════════════════════════════════════════════════════════════════════

# ── URL pública do frontend ───────────────────────────────────────────────────
# Exemplo: https://academia.seudominio.com.br
# Sem trailing slash. Usado em:
#   - ALLOWED_ORIGINS do Flask (CORS)
#   - NEXT_PUBLIC_API_URL = FRONTEND_URL/api (gerado pelo docker-compose)
FRONTEND_URL=https://PREENCHER.com.br

# ── Supabase ──────────────────────────────────────────────────────────────────
# Encontre em: painel Supabase → Project Settings → API
SUPABASE_URL=https://PREENCHER.supabase.co
SUPABASE_ANON_KEY=eyJ...PREENCHER
SUPABASE_SERVICE_ROLE_KEY=eyJ...PREENCHER
# JWT secret (opcional — usado só se você validar o token localmente)
SUPABASE_JWT_SECRET=

# ── Gunicorn ──────────────────────────────────────────────────────────────────
# Número de workers. Regra empírica: 2 × nº de CPUs + 1.
# Com 1 CPU (VPS básica): 2 workers. Com 2 CPUs: 4 workers.
WEB_CONCURRENCY=2

# ── Rate limiting ─────────────────────────────────────────────────────────────
# Padrões seguros para produção. Ajuste conforme o tráfego real.
RATELIMIT_DEFAULT=200 per minute
RATELIMIT_LOGIN=10 per minute;50 per hour
# Redis configurado automaticamente pelo docker-compose (redis://redis:6379/0)

# ── Avatares ──────────────────────────────────────────────────────────────────
# Nome do bucket no Supabase Storage (crie-o como público no painel)
AVATAR_BUCKET=avatars
AVATAR_MAX_BYTES=4194304
AVATAR_SIZE_PX=512

# ── E-mail (notificações de mensalidade) ──────────────────────────────────────
# Gmail com senha de app: https://myaccount.google.com/apppasswords
# (autenticação de 2 fatores deve estar ativada na conta Google)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=PREENCHER@gmail.com
EMAIL_PASSWORD=PREENCHER_SENHA_DE_APP_16_CHARS
EMAIL_FROM=PREENCHER@gmail.com
