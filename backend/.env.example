# ── Backend (Flask) — variáveis de ambiente ───────────────────────────────────
# Copie para `.env` e preencha. NUNCA versione o `.env` real (está no .gitignore).

# ── Supabase ───────────────────────────────────────────────────────────────────
SUPABASE_URL=https://SEU-PROJETO.supabase.co
# Chave pública (anon): usada em clientes por requisição (login / RLS).
SUPABASE_ANON_KEY=eyJ...anon...
# SECRETA: bypassa RLS. Só no backend. Nunca no frontend, em logs ou no git.
SUPABASE_SERVICE_ROLE_KEY=eyJ...service_role...
# Opcional (hoje não usada para validação local; o token é validado via Auth API).
SUPABASE_JWT_SECRET=

# ── CORS ───────────────────────────────────────────────────────────────────────
# Origens do Next.js separadas por vírgula. Em produção, sem localhost.
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Rate limiting (Flask-Limiter) ──────────────────────────────────────────────
# IMPORTANTE (B-3): "memory://" NÃO é compartilhado entre workers/instâncias —
# o controle de brute force no login fica enfraquecido. Em PRODUÇÃO use um
# backend compartilhado, ex.: redis://localhost:6379. (Requer `pip install redis`.)
RATELIMIT_STORAGE_URI=memory://
RATELIMIT_DEFAULT=200 per minute
RATELIMIT_LOGIN=10 per minute;50 per hour

# ── Avatares (foto de perfil) ──────────────────────────────────────────────────
AVATAR_BUCKET=avatars
AVATAR_MAX_BYTES=4194304
AVATAR_SIZE_PX=512

# ── E-mail (notificações de mensalidade) ───────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_FROM=
